PORT=5000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pos_accessories
DB_CONNECTION_LIMIT=10
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA_FILE=
DATABASE_URL=
DB_SSL_CA=
DB_CONNECT_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=60000
DB_MAX_IDLE=2


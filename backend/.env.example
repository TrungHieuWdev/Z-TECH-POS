JWT_EXPIRES_IN=8h
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=7
MFA_ENCRYPTION_KEY=replace_with_a_separate_random_secret_at_least_32_chars

FRONTEND_ORIGINS=http://localhost:5173
API_RATE_LIMIT=600
LOGIN_RATE_LIMIT=10
TRUST_PROXY=false
JSON_BODY_LIMIT=1mb
LOG_HTTP_SUCCESS=false
